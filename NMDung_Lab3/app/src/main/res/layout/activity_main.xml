<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="16dp"
            android:text="Lab 03 - Chon bai layout"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_bai1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Bai 1 - LinearLayout" />

        <Button
            android:id="@+id/btn_bai2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Bai 2 - RelativeLayout" />

        <Button
            android:id="@+id/btn_bai3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Bai 3 - ConstraintLayout" />

        <Button
            android:id="@+id/btn_bai4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Bai 4 - TableLayout" />

        <Button
            android:id="@+id/btn_bai5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Bai 5 - GridLayout" />

        <Button
            android:id="@+id/btn_bai6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bai 6 - FrameLayout" />

    </LinearLayout>
</ScrollView>